---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { SITE } from "@/config"
import Button from "@/components/Button.astro"
import SpotifyEmbed from "@/components/SpotifyEmbed.astro"
import CommunityBanner from "@/components/CommunityBanner.astro"
---
<BaseLayout title="Tentang" description="Jelajahi dunia di antara yang tampak dan tak terlihat.">
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6">
    <header class="mb-8">
      <span class="text-[9px] font-mono uppercase tracking-[0.2em] text-[var(--color-primary)] font-semibold">Profil</span>
      <h1 class="mt-2 font-serif text-3xl font-medium sm:text-4xl text-[var(--color-foreground)]">Tentang Sekala Niskala</h1>
      <p class="mt-2 text-base text-[var(--color-muted)]">
        Menjelajahi keheningan di antara yang kasat mata dan yang sunyi.
      </p>
    </header>

    <!-- Spiritual Forest Banner -->
    <img
      src="/hero_bg.jpg"
      alt="Hutan berkabut Sekala Niskala"
      class="mb-10 aspect-[21/9] w-full rounded-[var(--radius-lg)] object-cover shadow-[0_8px_24px_rgba(0,0,0,0.5)] border border-[var(--color-border)]/20"
    />

    <div class="prose max-w-none text-[var(--color-foreground)]">
      <h2 class="font-serif text-2xl font-medium text-[var(--color-primary)]">Filsafat Kami</h2>
      <p class="leading-relaxed">
        Sekala Niskala adalah ruang tulisan komunitas yang merenungkan dualitas 
        antara yang tampak (sekala) dan yang tak terlihat (niskala). Kami percaya 
        bahwa dunia nyata dan pengalaman batin saling melengkapi, menciptakan 
        narasi yang lebih kaya tentang kehidupan, perjalanan, dan makna.
      </p>

      <h2 class="font-serif text-2xl font-medium text-[var(--color-primary)] mt-8">Misi Kami</h2>
      <p class="leading-relaxed">
        Kami menyediakan platform untuk refleksi pribadi, catatan perjalanan, 
        dan eksplorasi spiritual yang autentik. Setiap tulisan adalah kontribusi 
        dari komunitas yang ingin berbagi wawasan, pengalaman, dan pemahaman 
        tentang berbagai aspek kehidupan.
      </p>

      <h2 class="font-serif text-2xl font-medium text-[var(--color-primary)] mt-8">Nilai-Nilai Kami</h2>
      <ul class="space-y-2 mt-4 pl-5 list-disc">
        <li><strong>Autentisitas:</strong> Tulisan yang tulus dan bersumber dari suara asli kontributor kami.</li>
        <li><strong>Refleksi:</strong> Mendalami makna di balik pengalaman sehari-hari.</li>
        <li><strong>Komunitas:</strong> Ruang kolaboratif untuk pertumbuhan bersama.</li>
        <li><strong>Jujur:</strong> Terbuka tentang proses, keraguan, dan penemuan spiritual.</li>
      </ul>

      <h2 class="font-serif text-2xl font-medium text-[var(--color-primary)] mt-8">Kontribusi</h2>
      <p class="leading-relaxed">
        Kami mengundang Anda untuk bergabung dengan kami dalam eksplorasi ini. 
        Kirimkan tulisan Anda tentang pengalaman pribadi, perjalanan spiritual, 
        atau refleksi tentang dunia sekala dan niskala.
      </p>

      <h2 class="font-serif text-2xl font-medium text-[var(--color-primary)] mt-8">Suara Keheningan</h2>
      <p class="leading-relaxed mb-5">
        Dengarkan pilihan lagu bertema spiritual dan ketenangan alam untuk menemani langkah meditasi dan saat membaca tulisan kami.
      </p>
      <SpotifyEmbed class="mb-8" />
    </div>

    <!-- Discord Banner, Media Links & Info -->
    <div class="mt-12 pt-8 border-t border-[var(--color-border)]/30 space-y-8">
      <CommunityBanner />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="font-serif text-base font-semibold mb-4 text-[var(--color-foreground)]">Media Lainnya</h3>
          <ul class="space-y-3.5 text-xs sm:text-sm text-[var(--color-muted)]">
            <li>
              <strong class="text-[var(--color-foreground)] font-medium">Instagram:</strong> 
              <a href="https://instagram.com/sekalaniskala" target="_blank" rel="noopener noreferrer" class="underline hover:text-[var(--color-primary)] ml-1">Sekala Niskala</a>
            </li>
            <li>
              <strong class="text-[var(--color-foreground)] font-medium">Quora:</strong> 
              <a href="https://sekalaniskalauniverse.quora.com/" target="_blank" rel="noopener noreferrer" class="underline hover:text-[var(--color-primary)] ml-1">Waroeng Podjok Mangkoes (Space)</a>
            </li>
            <li>
              <strong class="text-[var(--color-foreground)] font-medium">Spotify:</strong> 
              <span class="inline-flex gap-1 ml-1">
                <a href="https://open.spotify.com/" target="_blank" rel="noopener noreferrer" class="underline hover:text-[var(--color-primary)]">Sekala Niskala Universe</a> & 
                <a href="https://open.spotify.com/" target="_blank" rel="noopener noreferrer" class="underline hover:text-[var(--color-primary)]">Theme Songs</a>
              </span>
            </li>
            <li>
              <strong class="text-[var(--color-foreground)] font-medium">Web:</strong> 
              <a href="https://sekalaniskalauniverse.wordpress.com/" target="_blank" rel="noopener noreferrer" class="underline hover:text-[var(--color-primary)] ml-1">SEKALA NISKALA UNIVERSE</a>
            </li>
            <li>
              <strong class="text-[var(--color-foreground)] font-medium">Threads:</strong> 
              <a href="https://threads.net/@sekalaniskala_u" target="_blank" rel="noopener noreferrer" class="underline hover:text-[var(--color-primary)] ml-1">Sekala Niskala Universe (@sekalaniskala_u)</a>
            </li>
          </ul>
        </div>

        <div class="space-y-5">
          <div>
            <h3 class="font-serif text-base font-semibold mb-2 text-[var(--color-foreground)]">Hubungi Kami</h3>
            <p class="text-xs sm:text-sm text-[var(--color-muted)] leading-relaxed">
              Hubungi kami di:
              <a href="mailto:sekalaniskalauniverse@gmail.com" class="block font-mono text-[var(--color-primary)] font-semibold mt-1 hover:underline text-xs sm:text-sm">sekalaniskalauniverse@gmail.com</a>
            </p>
          </div>

          <div>
            <h3 class="font-serif text-base font-semibold mb-2 text-[var(--color-foreground)]">Dukungan & Donasi</h3>
            <p class="text-xs sm:text-sm text-[var(--color-muted)] leading-relaxed">
              Segala dukungan dan support bisa diberikan dalam bentuk donasi di:
              <a href="https://sociabuzz.com/sekalaniskala/tribe" target="_blank" rel="noopener noreferrer" class="block text-[var(--color-accent)] font-semibold mt-1 hover:underline text-xs sm:text-sm">Sekala Niskala | SociaBuzz TRIBE</a>
            </p>
          </div>
        </div>
      </div>

      <div class="mt-8 p-6 rounded-2xl border border-[var(--color-border)]/30 bg-[var(--color-surface-2)]/30 text-center space-y-2">
        <p class="text-sm italic text-[var(--color-foreground)] leading-relaxed">
          "If you treat us well, we will respond in kind. Let's show each other respect~✨"
        </p>
        <p class="text-xs font-semibold text-[var(--color-primary)] font-mono uppercase tracking-[0.1em] mt-2">
          Salam Hangat, SNU~🍀
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
