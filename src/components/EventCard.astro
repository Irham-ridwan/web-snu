---
import type { CollectionEntry } from "astro:content"
import { Image } from "astro:assets"
import EventStatus from "@/components/EventStatus.astro"
import Button from "@/components/Button.astro"
import { formatDate } from "@/lib/utils"

interface Props {
  event: CollectionEntry<"events">
  class?: string
}

const { event, class: className = "" } = Astro.props
const { title, description, startDate, location, cover } = event.data
---

<article
  class:list={[
    "flex flex-col overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-sm transition-all hover:border-[var(--color-primary)]/50 hover:shadow-md",
    className
  ]}
>
  <div class="relative aspect-[16/9] w-full bg-[var(--color-surface-2)] overflow-hidden">
    {
      cover ? (
        <Image
          src={cover}
          alt={`Ilustrasi untuk event ${title}`}
          width={400}
          height={225}
          class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center text-[var(--color-muted)]">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
        </div>
      )
    }
    <div class="absolute right-3 top-3">
      <EventStatus startDate={startDate} endDate={event.data.endDate} />
    </div>
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="mb-2 flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-[var(--color-primary)]">
      <span>{formatDate(startDate)}</span>
      <span class="text-[var(--color-border)]">•</span>
      <span class="truncate max-w-[150px]">{location}</span>
    </div>

    <h3 class="font-serif text-lg font-semibold leading-tight text-[var(--color-foreground)] hover:text-[var(--color-primary)]">
      <a href={`/events/${event.id || event.slug}`}>{title}</a>
    </h3>

    <p class="mt-2 flex-1 text-sm text-[var(--color-muted)] line-clamp-3">
      {description}
    </p>

    <div class="mt-4 pt-4 border-t border-[var(--color-border)]">
      <Button href={`/events/${event.id || event.slug}`} variant="secondary" size="sm" class="w-full text-center">
        Detail Event &rarr;
      </Button>
    </div>
  </div>
</article>
