---
import type { CollectionEntry } from "astro:content"
import { Image } from "astro:assets"
import EventStatus from "@/components/EventStatus.astro"
import Button from "@/components/Button.astro"
import { formatDate } from "@/lib/utils"
import coverTemple from "@/assets/cover_temple.jpg"
import coverMeditation from "@/assets/cover_meditation.jpg"

interface Props {
  event: CollectionEntry<"events">
  class?: string
}

const { event, class: className = "" } = Astro.props
const { title, description, startDate, location, cover } = event.data

const fallbackCovers = [
  coverTemple,
  coverMeditation,
]
const finalCover = cover || fallbackCovers[event.id.charCodeAt(0) % fallbackCovers.length]
const href = `/events/${event.id || event.slug}`
---

<article
  class:list={[
    "p-1.5 rounded-[1.75rem] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-[0_12px_24px_-12px_rgba(0,0,0,0.3)] transition-premium hover:shadow-[0_20px_32px_-10px_rgba(0,0,0,0.45)] hover:border-[var(--color-primary)]/30 hover:-translate-y-0.5 group flex flex-col",
    className
  ]}
>
  <div class="relative aspect-[16/9] w-full bg-[var(--color-surface-2)] overflow-hidden rounded-[1.375rem] border border-[var(--color-border)]/50">
    {
      finalCover && (
        <Image
          src={finalCover}
          alt={`Ilustrasi untuk event ${title}`}
          width={400}
          height={225}
          class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-103"
        />
      )
    }
    <div class="absolute right-3 top-3">
      <EventStatus startDate={startDate} endDate={event.data.endDate} />
    </div>
  </div>

  <div class="flex flex-1 flex-col p-4 sm:p-5 rounded-[1.375rem] bg-[var(--color-surface-2)]/30 border border-[var(--color-border)]/40 mt-2">
    <div class="mb-2 flex items-center gap-1.5 text-[9px] font-mono uppercase tracking-[0.12em] text-[var(--color-primary)]">
      <span>{formatDate(startDate)}</span>
      <span class="text-[var(--color-border)]">•</span>
      <span class="truncate max-w-[130px]">{location}</span>
    </div>

    <h3 class="font-serif text-lg font-medium leading-tight text-[var(--color-foreground)] transition-colors group-hover:text-[var(--color-primary)]">
      <a href={href}>{title}</a>
    </h3>

    <p class="mt-2.5 flex-1 text-sm text-[var(--color-muted)] line-clamp-3 leading-relaxed">
      {description}
    </p>

    <div class="mt-4 pt-4 border-t border-[var(--color-border)]/30">
      <Button href={href} variant="outline" size="sm" class="w-full text-center text-[10px] uppercase font-mono tracking-[0.1em]" hasArrow>
        Detail Event
      </Button>
    </div>
  </div>
</article>
