---
import { getCollection } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import Button from "@/components/Button.astro"
import { formatDate } from "@/lib/utils"
import siteSettings from "@/content/settings/site.json"

const enableGallery = siteSettings.enableGallery
const rawGallery = await getCollection("gallery")
const galleryEvents = rawGallery
  .filter((g) => import.meta.env.DEV || !g.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<BaseLayout title="Galeri Dokumentasi" description="Dokumentasi foto kegiatan dan outbound Sekala Niskala Universe.">
  <div class="mx-auto max-w-5xl px-4 py-14 sm:px-6">
    {
      !enableGallery ? (
        <div class="min-h-[50vh] flex flex-col items-center justify-center text-center py-20 px-4">
          <div class="h-20 w-20 rounded-full border border-[var(--color-primary)]/20 bg-[var(--color-surface-2)]/50 flex items-center justify-center mb-6 relative">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="animate-pulse">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="9" y1="17" x2="9" y2="10"></line>
              <line x1="15" y1="17" x2="15" y2="14"></line>
            </svg>
          </div>
          <h1 class="font-serif text-3xl font-bold tracking-tight text-[var(--color-foreground)] mb-3">Fitur Dinonaktifkan</h1>
          <p class="text-sm text-[var(--color-muted)] max-w-md mb-8 leading-relaxed">
            Halaman Galeri Dokumentasi saat ini sedang dinonaktifkan oleh administrator. Silakan aktifkan opsi "Aktifkan Fitur Galeri Dokumentasi" melalui panel Keystatic CMS Anda untuk menampilkannya di publik.
          </p>
          <Button href="/">Kembali ke Beranda &rarr;</Button>
        </div>
      ) : (
        <section aria-labelledby="gallery-title" class="space-y-12">
          <div class="space-y-4 text-center max-w-2xl mx-auto mb-14">
            <span class="text-xs font-mono uppercase tracking-[0.2em] text-[var(--color-accent)]">Dokumentasi</span>
            <h1 id="gallery-title" class="font-serif text-4xl sm:text-5xl font-bold tracking-tight text-[var(--color-foreground)]">Galeri Kegiatan SNU</h1>
            <div class="h-0.5 w-16 bg-[var(--color-primary)]/40 mx-auto"></div>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">
              Arsip visual kegiatan outbound, retret meditasi, dan kongkow komunitas Sekala Niskala Universe.
            </p>
          </div>

          {galleryEvents.length === 0 ? (
            <div class="p-12 text-center rounded-2xl border border-[var(--color-border)]/50 bg-[var(--color-surface-2)]/20">
              <p class="text-sm text-[var(--color-muted)]">Belum ada dokumentasi foto yang diunggah. Masuk ke Keystatic CMS untuk menambahkan album kegiatan baru!</p>
            </div>
          ) : (
            <div class="space-y-16">
              {galleryEvents.map((event) => (
                <div class="p-1.5 rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-lg flex flex-col gap-6">
                  <div class="p-6 sm:p-8 rounded-[1.75rem] bg-[var(--color-surface-2)]/30 border border-[var(--color-border)]/40 space-y-4">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 border-b border-[var(--color-border)]/20 pb-4">
                      <div>
                        <h2 class="font-serif text-2xl font-bold text-[var(--color-foreground)]">{event.data.title}</h2>
                        <p class="text-xs text-[var(--color-muted)] mt-1">{event.data.description}</p>
                      </div>
                      <span class="text-[10px] font-mono uppercase tracking-[0.1em] text-[var(--color-accent)] self-start sm:self-center bg-[var(--color-accent)]/15 border border-[var(--color-accent)]/20 px-3 py-1 rounded-full">
                        {formatDate(event.data.date)}
                      </span>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 pt-2">
                      {event.data.images && event.data.images.map((img) => (
                        <div class="group relative overflow-hidden rounded-2xl border border-[var(--color-border)]/50 bg-[var(--color-surface)] aspect-[4/3]">
                          <img
                            src={img.image}
                            alt={img.caption || ""}
                            class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                          />
                          {img.caption && (
                            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                              <p class="text-[10px] font-mono text-white leading-relaxed">{img.caption}</p>
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </section>
      )
    }
  </div>
</BaseLayout>
