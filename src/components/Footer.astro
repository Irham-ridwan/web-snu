---
import { NAV_LINKS, SITE } from "@/config"
const year = new Date().getFullYear()
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <div class="flex items-center gap-3">
          <!-- Mystical gold mandala flower SVG logo -->
          <div class="relative flex items-center justify-center h-8 w-8 rounded-full bg-[var(--color-surface-2)]/30 border border-[var(--color-primary)]/10 p-1">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M12 2C9.5 4.5 9.5 7.5 12 10c2.5-2.5 2.5-5.5 0-8ZM12 22c2.5-2.5 2.5-5.5 0-8-2.5 2.5-2.5 5.5 0 8ZM2 12c2.5 2.5 5.5 2.5 8 0-2.5-2.5-5.5-2.5-8 0ZM22 12c-2.5-2.5-5.5-2.5-8 0 2.5 2.5 5.5 2.5 8 0Z" fill="var(--color-primary)" opacity="0.85"></path>
              <path d="M12 12c1.5-1.5 3.5-1.5 5 0-1.5 1.5-3.5 1.5-5 0ZM12 12c-1.5 1.5-3.5 1.5-5 0 1.5-1.5 3.5-1.5 5 0ZM12 12c1.5 1.5 1.5 3.5 0 5-1.5-1.5-1.5-3.5 0-5ZM12 12c-1.5-1.5-1.5-3.5 0-5 1.5 1.5 1.5 3.5 0 5Z" fill="var(--color-accent)" opacity="0.9"></path>
              <circle cx="12" cy="12" r="2.5" fill="var(--color-primary)"></circle>
            </svg>
          </div>
          <span class="font-serif text-base font-semibold">Sekala Niskala</span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
          {SITE.description}
        </p>
      </div>

      <nav aria-label="Tautan footer" class="flex flex-col gap-2">
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
          Jelajah
        </h2>
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)]"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <nav aria-label="Tautan eksternal" class="flex flex-col gap-2">
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
          Komunitas
        </h2>
        <a href="/cari" class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)]">Pencarian</a>
        <a href="/rss.xml" class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-foreground)]">RSS Feed</a>
      </nav>
    </div>

    <div
      class="mt-10 flex flex-col items-center justify-between gap-2 border-t border-[var(--color-border)] pt-6 text-xs text-[var(--color-muted)] sm:flex-row"
    >
      <p>&copy; {year} Komunitas Sekala Niskala. Yang tampak dan yang tak tampak.</p>
      <p>Dibangun dengan Astro &amp; kabut subuh.</p>
    </div>
  </div>
</footer>
